<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/areYouThereRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/overlayBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <ImageView
            android:id="@+id/imageAppLogo"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_launcher_foreground"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/textAppName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:textSize="24sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:text="@string/app_name" />

        <TextView
            android:id="@+id/textAreYouThereTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:textSize="36sp"
            android:gravity="center"
            android:text="@string/are_you_there_title" />

        <TextView
            android:id="@+id/textAreYouThereMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/are_you_there_message" />

        <TextView
            android:id="@+id/textAreYouThereCountdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/monitoringImpaired"
            android:textStyle="bold"
            android:textSize="22sp"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:text="@string/are_you_there_countdown" />

        <Button
            android:id="@+id/buttonImOk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:textAllCaps="true"
            android:text="@string/are_you_there_im_ok" />

        <Button
            android:id="@+id/buttonOpenApp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textAllCaps="true"
            android:text="@string/are_you_there_open_app" />

        <Button
            android:id="@+id/buttonDismiss"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textAllCaps="true"
            android:text="@string/are_you_there_dismiss" />

    </LinearLayout>

</FrameLayout>
